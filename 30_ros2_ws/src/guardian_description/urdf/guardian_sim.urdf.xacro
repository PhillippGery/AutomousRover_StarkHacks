<?xml version="1.0"?>
<robot name="guardian" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ── Materials ─────────────────────────────────────────────────────────── -->
  <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
  <material name="blue">    <color rgba="0.1 0.4 0.8 1.0"/></material>
  <material name="red">     <color rgba="0.8 0.1 0.1 1.0"/></material>

  <!-- ── Chassis ───────────────────────────────────────────────────────────── -->
  <!-- base_link origin at ground level; chassis box centred at z=0.05 (half height) -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.2312 0.200 0.100"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.2312 0.200 0.100"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia ixx="0.01517" ixy="0" ixz="0"
               iyy="0.02250" iyz="0"
               izz="0.03118"/>
    </inertial>
  </link>

  <!-- ── Wheels ────────────────────────────────────────────────────────────── -->
  <!-- Wheel axles at z=0.0748 (wheel_radius) so wheels rest on z=0 ground    -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.0748" length="0.05"/></geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.0748" length="0.05"/></geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <!-- solid cylinder: ixx=iyy=m(3r²+h²)/12, izz=mr²/2 -->
        <inertia ixx="0.001561" ixy="0" ixz="0"
                 iyy="0.001561" iyz="0"
                 izz="0.001401"/>
      </inertial>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel"/>
      <origin xyz="${x} ${y} 0.0748" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01"/>
    </joint>
    <gazebo reference="${name}_wheel">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <material>Gazebo/Blue</material>
    </gazebo>
  </xacro:macro>

  <xacro:wheel name="front_left"  x=" 0.0856" y=" 0.120"/>
  <xacro:wheel name="front_right" x=" 0.0856" y="-0.120"/>
  <xacro:wheel name="rear_left"   x="-0.0856" y=" 0.120"/>
  <xacro:wheel name="rear_right"  x="-0.0856" y="-0.120"/>

  <!-- ── Lidar link ────────────────────────────────────────────────────────── -->
  <link name="laser">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.03"/></geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser"/>
    <origin xyz="0.0 0.0 0.175" rpy="0 0 0"/>
  </joint>

  <!-- ── Gazebo: chassis colour ────────────────────────────────────────────── -->
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- ── Gazebo: GPU Lidar sensor ──────────────────────────────────────────── -->
  <gazebo reference="laser">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0 0 0.015 0 0 0</pose>
      <topic>/scan</topic>
      <gz_frame_id>laser</gz_frame_id>
      <update_rate>5</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>500</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle>3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ── Gazebo: DiffDrive plugin ──────────────────────────────────────────── -->
  <!-- Groups FL+BL as left, FR+BR as right — approximates mecanum for SLAM   -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.240</wheel_separation>
      <wheel_radius>0.0748</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <tf_topic>/tf</tf_topic>
    </plugin>
  </gazebo>

  <!-- ── Gazebo: Joint state publisher ─────────────────────────────────────── -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>
  </gazebo>

</robot>
