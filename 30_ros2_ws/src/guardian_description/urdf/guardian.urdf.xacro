  <!-- TODO: define material properties -->

  <!-- base_link — center of chassis at ground level -->
  <link name="base_link">
    <!-- TODO: add visual and collision geometry -->
    <inertial>
      <!-- TODO: add inertia from CAD model -->
      <mass value="5.0"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0"
               iyy="0.1" iyz="0"
               izz="0.1"/>
    </inertial>
  </link>

  <!-- TODO: add wheel links (FL, FR, BL, BR) -->
